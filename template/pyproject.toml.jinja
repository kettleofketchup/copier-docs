[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ site_description }}"
requires-python = ">=3.12"
dependencies = [
    "zensical>=0.0.43",
]

[dependency-groups]
dev = [
    "lefthook>=1.7.0",
    "codespell>=2.3.0",
    "ruff>=0.7.0",
    "pymarkdownlnt>=0.9.0",
]

[tool.ruff]
line-length = 100
target-version = "py312"

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B"]
