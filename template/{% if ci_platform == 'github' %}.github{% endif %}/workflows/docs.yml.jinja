name: Docs

on:
  pull_request:
  push:
    branches: [main, master]

jobs:
  lint-build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install uv
        uses: astral-sh/setup-uv@v4
        with:
          enable-cache: true

      - name: Install just
        uses: extractions/setup-just@v2

      - run: uv sync

      - name: Lint
        run: just docs::lint

      - name: Build
        run: just docs::build

      - name: Upload site
        uses: actions/upload-artifact@v4
        with:
          name: site
          path: site/
