[project]
site_name = "{{ site_name }}"
site_url = "{{ site_url }}"
site_description = "{{ site_description }}"
site_author = "{{ author }}"
copyright = "&copy; {{ author }}"
docs_dir = "docs"
site_dir = "site"
use_directory_urls = true
dev_addr = "localhost:8000"
extra_css = ["stylesheets/extra.css"]
{%- if repo_url %}
repo_url = "{{ repo_url }}"
repo_name = "{{ repo_url.rstrip('/').split('/')[-2:] | join('/') }}"
edit_uri = "{% if ci_platform == 'gitlab' %}-/edit/main/docs/{% else %}edit/main/docs/{% endif %}"
{%- endif %}

nav = [
  {"Home" = "index.md"},
  {"Showcase" = "showcase.md"},
]

# navigation.instant is intentionally absent: it breaks the logo/header when
# the serving host differs from site_url (localhost preview, Pages prefix).
[project.theme]
variant = "classic"
features = [
  "navigation.tracking",
  "navigation.tabs",
  "navigation.sections",
  "navigation.indexes",
  "navigation.top",
  "navigation.footer",
  "toc.follow",
  "search.suggest",
  "search.highlight",
  "content.code.copy",
  "content.tabs.link",
  "content.tooltips",
{%- if repo_url %}
  "content.action.edit",
  "content.action.view",
{%- endif %}
]
{%- if repo_url %}

[project.theme.icon]
repo = "{% if ci_platform == 'gitlab' %}material/gitlab{% else %}material/github{% endif %}"
edit = "material/pencil"
{%- endif %}

[project.theme.palette]
scheme = "slate"
primary = "deep-purple"
accent = "purple"

# Full default extension set: configuring any single extension disables
# zensical's implicit defaults, so list them all explicitly.
[project.markdown_extensions.abbr]

[project.markdown_extensions.admonition]

[project.markdown_extensions.attr_list]

[project.markdown_extensions.def_list]

[project.markdown_extensions.footnotes]

[project.markdown_extensions.md_in_html]

[project.markdown_extensions.toc]
permalink = true

[project.markdown_extensions.pymdownx.arithmatex]
generic = true

[project.markdown_extensions.pymdownx.betterem]

[project.markdown_extensions.pymdownx.caret]

[project.markdown_extensions.pymdownx.details]

[project.markdown_extensions.pymdownx.emoji]
emoji_generator = "zensical.extensions.emoji.to_svg"
emoji_index = "zensical.extensions.emoji.twemoji"

[project.markdown_extensions.pymdownx.highlight]
anchor_linenums = true
line_spans = "__span"
pygments_lang_class = true

[project.markdown_extensions.pymdownx.inlinehilite]

[project.markdown_extensions.pymdownx.keys]

[project.markdown_extensions.pymdownx.magiclink]

[project.markdown_extensions.pymdownx.mark]

[project.markdown_extensions.pymdownx.smartsymbols]

[project.markdown_extensions.pymdownx.superfences]
custom_fences = [
  { name = "mermaid", class = "mermaid", format = "pymdownx.superfences.fence_code_format" },
]

[project.markdown_extensions.pymdownx.tabbed]
alternate_style = true
combine_header_slug = true

[project.markdown_extensions.pymdownx.tasklist]
custom_checkbox = true

[project.markdown_extensions.pymdownx.tilde]

# Site-wide glossary: auto-append abbreviations to every page.
[project.markdown_extensions.pymdownx.snippets]
base_path = ["docs", "."]
auto_append = ["includes/abbreviations.md"]
check_paths = true
{%- if repo_url %}

[[project.extra.social]]
icon = "{% if ci_platform == 'gitlab' %}material/gitlab{% else %}material/github{% endif %}"
link = "{{ repo_url }}"
name = "Edit these docs on {% if ci_platform == 'gitlab' %}GitLab{% else %}GitHub{% endif %}"
{%- endif %}
