stages:
  - lint
  - build
  - pages
  - docker

default:
  interruptible: true

workflow:
  rules:
    - if: $CI_PIPELINE_SOURCE == "merge_request_event"
    - if: $CI_COMMIT_BRANCH && $CI_OPEN_MERGE_REQUESTS
      when: never
    - if: $CI_COMMIT_BRANCH
    - if: $CI_COMMIT_TAG

# Shared setup: uv image + just installed to /usr/local/bin, deps synced.
.uv-just:
  image: ghcr.io/astral-sh/uv:python3.12-bookworm
  before_script:
    - apt-get update && apt-get install -y --no-install-recommends git curl
    - curl --proto '=https' --tlsv1.2 -sSf https://just.systems/install.sh | bash -s -- --to /usr/local/bin
    - uv sync

lint:
  stage: lint
  extends: .uv-just
  script:
    - just cicd::lint
  rules:
    - if: $CI_PIPELINE_SOURCE == "merge_request_event"
    - if: $CI_COMMIT_BRANCH

build:
  stage: build
  extends: .uv-just
  script:
    - just cicd::build
  artifacts:
    paths:
      - site
    expire_in: 1 week
  rules:
    - if: $CI_PIPELINE_SOURCE == "merge_request_event"
    - if: $CI_COMMIT_BRANCH

pages:
  stage: pages
  extends: .uv-just
  script:
    - just cicd::pages
  pages:
    publish: site
  artifacts:
    paths:
      - site
  rules:
    - if: $CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH

docker:
  stage: docker
  image: docker:latest
  services:
    - docker:dind
  variables:
    DOCKER_TAG: "{{ gitlab_registry }}:${CI_COMMIT_SHORT_SHA}"
    DOCKER_LATEST: "{{ gitlab_registry }}:latest"
  before_script:
    - docker login -u "$CI_REGISTRY_USER" -p "$CI_REGISTRY_PASSWORD" "$CI_REGISTRY"
  script:
    - docker build -t "$DOCKER_TAG" -t "$DOCKER_LATEST" -f docker/Dockerfile .
    - docker push "$DOCKER_TAG"
    - docker push "$DOCKER_LATEST"
  rules:
    - if: $CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH
    - if: $CI_COMMIT_TAG
