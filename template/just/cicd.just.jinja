# CI/CD recipes — platform-agnostic build commands called by
# {% if ci_platform == 'gitlab' %}GitLab CI{% else %}GitHub Actions{% endif %}.
# Keep CI YAML thin: it should only call `just cicd::*`.

{% if ci_platform == 'gitlab' -%}
REGISTRY := "{{ gitlab_registry }}"
{%- else -%}
REGISTRY := "{{ github_registry }}"
{%- endif %}
IMAGE := REGISTRY
VERSION := `git describe --tags --always 2>/dev/null || echo "dev"`

# Lint docs: markdown syntax + spelling (+ ruff if any python is present)
[no-cd]
[group('cicd')]
lint:
    uv run pymarkdown --disable-rules MD013,MD033,MD041,MD030,MD046 scan docs
    uv run codespell docs

# Build the static site into site/
[no-cd]
[group('cicd')]
build:
    uv run zensical build

# Alias used by the Pages jobs (publishes the site/ directory)
[no-cd]
[group('cicd')]
pages: build

# Build the nginx docs image (tag defaults to IMAGE:VERSION)
[no-cd]
[group('cicd')]
docker tag=(IMAGE + ":" + VERSION):
    docker build -t {{ '{{' }} tag {{ '}}' }} -t {{ '{{' }} IMAGE {{ '}}' }}:latest -f docker/Dockerfile .

# Build and push the docs image
[no-cd]
[group('cicd')]
docker-push tag=(IMAGE + ":" + VERSION): (docker tag)
    docker push {{ '{{' }} tag {{ '}}' }}
    docker push {{ '{{' }} IMAGE {{ '}}' }}:latest
